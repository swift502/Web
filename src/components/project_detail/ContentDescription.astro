---
import { renderMarkdown } from '../../scripts/astro-helpers';
import type { ContentBlockData } from '../../scripts/interfaces';

interface Props {
	blockData: ContentBlockData<any>;
	parentId: string;
}
const { blockData, parentId } = Astro.props;
---

{blockData.properties.desc && (
	<div
		class="content-description markdown"
		data-target={parentId}
		set:html={renderMarkdown(blockData.properties.desc)}
	/>
)}

<style>
	.content-description {
		display: block;
		position: relative;
		padding: 22px 30px;
		box-sizing: border-box;
		background: #fff;
		border-radius: 0px 0px 10px 10px;
		box-shadow: 0px 1px 2px 0px rgba(0, 0, 0, 0.4);
	}

	@media (max-width: 776px) {
		.content-description {
			background: none;
			box-shadow: none;
			padding: 22px;
			padding-bottom: 0px;
			margin-bottom: 22px;
		}
	}
</style>

<style is:global>
	@media (max-width: 776px) {
		.content-block:last-of-type .content-description {
			margin-bottom: 0;
		}
	}
</style>