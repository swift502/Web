---
import { renderMarkdown } from '../scripts/astro-helpers';
import ContentBlock from '../components/project_detail/ContentBlock.astro';
import type { ContentBlockData, TextProperties } from '../scripts/interfaces';

interface Props {
	blockData: ContentBlockData<TextProperties>;
}
const { blockData } = Astro.props;
---

<ContentBlock>
	<div class="text-block markdown" set:html={renderMarkdown(blockData.properties.data)} />
</ContentBlock>

<style>
	.text-block {
		width: 100%;
	}

	@media (max-width: 776px) {
		.text-block {
			padding: 22px;
			/* padding-bottom: 0px; */
			box-sizing: border-box;
		}

		.content-block:last-of-type .text-block {
			padding-bottom: 0;
		}
	}
</style>

<style is:global>
	@media (max-width: 776px) {
		.content-block:last-of-type .text-block {
			padding-bottom: 0;
		}
	}
</style>
