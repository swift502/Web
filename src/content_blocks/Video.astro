---
import FrameView from "../components/project_detail/FrameView.astro";
import MediaControls from "../components/project_detail/MediaControls.astro";
import type { ContentBlockData, VideoProperties } from "../scripts/interfaces";

interface Props {
	blockData: ContentBlockData<VideoProperties>;
}
const { blockData } = Astro.props;

const videoPath = `/assets/projects/${blockData.project.name}/${blockData.properties.data}`;
const width = blockData.properties.width ?? 16;
const height = blockData.properties.height ?? 9;
---

<FrameView
	blockData={blockData}
	width={width}
	height={height}
>
	<video autoplay muted loop onloadeddata="fadeIn(this)">
		<source src={videoPath} type="video/webm"/>
	</video>
	<MediaControls
		name={blockData.properties.data}
		path={videoPath}
	/>
</FrameView>

<style>
	video {
		opacity: 0;
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>