---
import FrameView from "../components/project_detail/FrameView.astro";
import type { ContentBlockData, YoutubeProperties } from "../scripts/interfaces";

interface Props {
	blockData: ContentBlockData<YoutubeProperties>;
}
const { blockData } = Astro.props;
---

<FrameView
	blockData={blockData}
	width={16}
	height={9}
>
	<iframe
		src={`https://www.youtube-nocookie.com/embed/${blockData.properties.data}?rel=0`}
		title="Youtube video player"
		allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		allowfullscreen
		onload="fadeIn(this)"
	/>
</FrameView>

<style>
	iframe {
		opacity: 0;
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}
</style>